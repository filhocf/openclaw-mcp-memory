{
  "name": "@filhocf/openclaw-mcp-memory",
  "version": "0.1.0",
  "description": "Native OpenClaw plugin for mcp-memory-service: persistent memory with hybrid search, knowledge graph, and mistake notes",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "openclaw": {
    "extensions": ["./src/index.ts"],
    "install": {
      "npmSpec": "@filhocf/openclaw-mcp-memory",
      "defaultChoice": "npm"
    },
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "@xenova/transformers": "^2.17.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/better-sqlite3": "^7.6.0"
  },
  "license": "MIT"
}
